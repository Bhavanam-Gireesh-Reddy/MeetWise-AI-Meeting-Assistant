# ── Local Development ────────────────────────────────────────────────────────
# Backend FastAPI server URL (server-side only, used by next.config.mjs rewrites)
BACKEND_URL=http://127.0.0.1:8000

# ── Production (Render) ─────────────────────────────────────────────────────
# BACKEND_URL is automatically injected by render.yaml from meetwise-api's
# RENDER_EXTERNAL_URL — no manual action needed on Render.
#
# How it works (Hybrid Single-Domain):
#   User visits: https://meetwise-frontend.onrender.com/api/...
#   Next.js rewrites it internally to: https://meetwise-api.onrender.com/api/...
#   Result: Only ONE public URL is ever exposed to the user. No CORS issues.
